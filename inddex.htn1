<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>仿手机交互网页</title>
    <style>
        :root {
            --primary-color: #07c160;
            --bg-color: #ededed;
            --text-main: #000;
            --text-grey: #888;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

        body {
            background: #333;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        /* 模拟手机容器 */
        #phone-shell {
            width: 100%;
            max-width: 414px;
            height: 100%;
            max-height: 896px;
            background: #fff;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }

        /* 顶部状态栏 */
        .status-bar {
            height: 44px;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
            font-weight: bold;
            z-index: 100;
        }

        /* 主体内容区域 */
        #viewport {
            flex: 1;
            position: relative;
            overflow: hidden;
        }

        .page {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: var(--bg-color);
            display: none;
            flex-direction: column;
        }

        .page.active { display: flex; }

        /* 桌面模式样式 */
        #page-home {
            background: linear-gradient(to bottom, #4facfe 0%, #00f2fe 100%);
            padding: 20px;
        }
        .app-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-top: 20px;
        }
        .app-icon {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: white;
            font-size: 12px;
        }
        .icon-box {
            width: 60px; height: 60px;
            background: white;
            border-radius: 12px;
            margin-bottom: 5px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 30px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        /* 列表通用样式 */
        .header-title {
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            border-bottom: 1px solid #ddd;
            background: var(--bg-color);
        }

        .list-item {
            display: flex;
            padding: 12px 15px;
            background: white;
            align-items: center;
            border-bottom: 0.5px solid #eee;
        }
        .avatar {
            width: 48px; height: 48px;
            border-radius: 6px;
            background: #ccc;
            margin-right: 12px;
        }

        /* 聊天详情页 (独立于Tab外) */
        #chat-detail {
            z-index: 200;
            background: var(--bg-color);
            transform: translateX(100%);
            transition: transform 0.3s ease;
        }
        #chat-detail.open { transform: translateX(0); }

        .chat-messages {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .msg { max-width: 70%; padding: 8px 12px; border-radius: 6px; font-size: 15px; position: relative; }
        .msg.recv { background: white; align-self: flex-start; }
        .msg.sent { background: var(--primary-color); color: white; align-self: flex-end; }

        .chat-input-area {
            height: 60px;
            background: #f7f7f7;
            display: flex;
            align-items: center;
            padding: 0 10px;
            border-top: 1px solid #ddd;
        }
        input { flex: 1; height: 36px; border-radius: 4px; border: none; padding: 0 10px; outline: none; }
        .btn-send { margin-left: 10px; color: var(--primary-color); font-weight: bold; }

        /* 底部导航栏 */
        #nav-bar {
            height: 60px;
            display: flex;
            background: #f7f7f7;
            border-top: 1px solid #ddd;
        }
        .nav-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: #555;
        }
        .nav-item.active { color: var(--primary-color); }
    </style>
</head>
<body>

<div id="phone-shell">
    <div class="status-bar">
        <span id="clock">12:00</span>
        <div>📶 🔋</div>
    </div>

    <div id="viewport">
        <section id="page-home" class="page active">
            <div class="app-grid">
                <div class="app-icon" onclick="switchTab('message')">
                    <div class="icon-box" style="background: #07c160;">💬</div>
                    <span>微信</span>
                </div>
                <div class="app-icon">
                    <div class="icon-box" style="background: #108ee9;">🔹</div>
                    <span>支付宝</span>
                </div>
            </div>
        </section>

        <section id="page-message" class="page">
            <div class="header-title">微信</div>
            <div class="list-item" onclick="openChat('张三')">
                <div class="avatar" style="background: #ff9500;"></div>
                <div style="flex:1">
                    <div style="display:flex; justify-content:space-between"><b>张三</b><small style="color:#999">17:45</small></div>
                    <p style="color:#888; font-size:13px; margin-top:4px">今晚出来吃火锅吗？</p>
                </div>
            </div>
        </section>

        <section id="page-contacts" class="page">
            <div class="header-title">通讯录</div>
            <div style="padding: 10px; color: #888; font-size: 12px;">常用联系人</div>
            <div class="list-item"><div class="avatar" style="background: #4cd964;"></div>阿强</div>
            <div class="list-item"><div class="avatar" style="background: #5856d6;"></div>白老师</div>
        </section>

        <section id="chat-detail" class="page">
            <div class="header-title">
                <span style="position:absolute; left:15px; cursor:pointer" onclick="closeChat()">〈 返回</span>
                <span id="chat-user-name">张三</span>
            </div>
            <div class="chat-messages" id="msg-container">
                <div class="msg recv">在吗？</div>
                <div class="msg sent">在的，怎么了？</div>
            </div>
            <div class="chat-input-area">
                <input type="text" id="chat-input" placeholder="输入消息...">
                <div class="btn-send" onclick="sendMessage()">发送</div>
            </div>
        </section>
    </div>

    <nav id="nav-bar" style="display: none;">
        <div class="nav-item" onclick="switchTab('message')">💬<br>消息</div>
        <div class="nav-item" onclick="switchTab('contacts')">👥<br>联系人</div>
        <div class="nav-item" onclick="goHome()">🏠<br>桌面</div>
    </nav>
</div>

<script>
    // 更新时钟
    function updateClock() {
        const now = new Date();
        document.getElementById('clock').innerText = now.getHours() + ":" + String(now.getMinutes()).padStart(2, '0');
    }
    setInterval(updateClock, 1000);
    updateClock();

    // 切换底部Tab
    function switchTab(tabId) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById('page-' + tabId).classList.add('active');
        document.getElementById('nav-bar').style.display = 'flex';
        
        // 更新图标颜色
        document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
        // 简单逻辑判断
        if(tabId === 'message') document.querySelectorAll('.nav-item')[0].classList.add('active');
        if(tabId === 'contacts') document.querySelectorAll('.nav-item')[1].classList.add('active');
    }

    // 回桌面
    function goHome() {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById('page-home').classList.add('active');
        document.getElementById('nav-bar').style.display = 'none';
        document.getElementById('chat-detail').classList.remove('open');
    }

    // 聊天详情交互
    function openChat(name) {
        document.getElementById('chat-user-name').innerText = name;
        document.getElementById('chat-detail').classList.add('open');
        document.getElementById('chat-detail').style.display = 'flex';
    }

    function closeChat() {
        document.getElementById('chat-detail').classList.remove('open');
        setTimeout(() => {
            document.getElementById('chat-detail').style.display = 'none';
        }, 300);
    }

    function sendMessage() {
        const input = document.getElementById('chat-input');
        const container = document.getElementById('msg-container');
        if(!input.value.trim()) return;

        const msgDiv = document.createElement('div');
        msgDiv.className = 'msg sent';
        msgDiv.innerText = input.value;
        container.appendChild(msgDiv);
        
        input.value = '';
        container.scrollTop = container.scrollHeight;

        // 模拟简单自动回复
        setTimeout(() => {
            const replyDiv = document.createElement('div');
            replyDiv.className = 'msg recv';
            replyDiv.innerText = '收到！[自动回复]';
            container.appendChild(replyDiv);
            container.scrollTop = container.scrollHeight;
        }, 1000);
    }
</script>

</body>
</html>
